# API Base URL – used for all API calls (from FRONTEND_INTEGRATION.md)
# Development (CAA Backend default port 3000):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Production – set to your API host. Do NOT use localhost in production.
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# Client portal URL for {{login_url}} in login credential emails (optional).
# NEXT_PUBLIC_APP_URL=https://ca.navedhana.com
